<Window x:Class="CyberLikh.Welcome"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CyberLikh"
        mc:Ignorable="d"
        Title="Welcome" Height="450" Width="800">
    <Grid>

        <!-- Input bubble -->
        <Border HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Margin="230,260,0,0"
                Width="320"
                Height="46"
                CornerRadius="12"
                BorderBrush="#dc2626"
                BorderThickness="2"
                Background="White">
            <DockPanel LastChildFill="True">
                <Button Cursor="Hand"
                        Foreground="White"
                        FontSize="16"
                        BorderThickness="0,0,0,4"
                        BorderBrush="#7f1d1d"
                        Width="46"
                        Height="46"
                        DockPanel.Dock="Right"
                        Click="SendButton_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#dc2626"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="border"
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="0,10,10,0">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="border" Property="Background" Value="#ef4444"/>
                                                <Setter TargetName="border" Property="BorderThickness" Value="0,0,0,6"/>
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter TargetName="border" Property="Background" Value="#b91c1c"/>
                                                <Setter TargetName="border" Property="BorderThickness" Value="0,0,0,2"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                    <TextBlock Text="➤" Foreground="White" FontSize="16"/>
                </Button>

                <TextBox x:Name="NameInput"
                         TextWrapping="Wrap"
                         FontSize="16"
                         Padding="8"
                         BorderThickness="0"
                         Background="Transparent"/>
            </DockPanel>
        </Border>
        <Label Content="CyberLikhApp" HorizontalAlignment="Center" Margin="0,140,0,0" VerticalAlignment="Top" Foreground="#FFDC2626" FontFamily="Segoe UI Black" FontSize="36" RenderTransformOrigin="0.341,0.536"/>
        <Label Content="Please Enter Your Name" HorizontalAlignment="Center" Margin="0,217,0,0" VerticalAlignment="Top" FontFamily="Segoe UI Black" FontSize="18"/>
        <Image HorizontalAlignment="Left" Height="189" Margin="622,-33,0,0" VerticalAlignment="Top" Width="225" Source="/pngtree-artistic-hand-drawn-arrows-pack-png-image_15925603.png" RenderTransformOrigin="0.5,0.5">
            <Image.RenderTransform>
                <TransformGroup>
                    <ScaleTransform/>
                    <SkewTransform/>
                    <RotateTransform Angle="58.538"/>
                    <TranslateTransform/>
                </TransformGroup>
            </Image.RenderTransform>
        </Image>
        <Image HorizontalAlignment="Left" Height="189" Margin="-43,-11,0,0" VerticalAlignment="Top" Width="225" Source="/pngtree-artistic-hand-drawn-arrows-pack-png-image_15925603.png" RenderTransformOrigin="0.5,0.5">
            <Image.RenderTransform>
                <TransformGroup>
                    <ScaleTransform/>
                    <SkewTransform/>
                    <RotateTransform Angle="147.703"/>
                    <TranslateTransform/>
                </TransformGroup>
            </Image.RenderTransform>
        </Image>
        <Image HorizontalAlignment="Left" Height="188" Margin="635,274,0,0" VerticalAlignment="Top" Width="225" Source="/pngtree-artistic-hand-drawn-arrows-pack-png-image_15925603.png" RenderTransformOrigin="0.631,-0.055">
            <Image.RenderTransform>
                <TransformGroup>
                    <ScaleTransform/>
                    <SkewTransform/>
                    <RotateTransform Angle="66.633"/>
                    <TranslateTransform X="79.035" Y="95.03"/>
                </TransformGroup>
            </Image.RenderTransform>
        </Image>
        <Image HorizontalAlignment="Left" Height="189" Margin="-10,282,0,0" VerticalAlignment="Top" Width="225" Source="/pngtree-artistic-hand-drawn-arrows-pack-png-image_15925603.png" RenderTransformOrigin="0.5,0.5">
            <Image.RenderTransform>
                <TransformGroup>
                    <ScaleTransform/>
                    <SkewTransform/>
                    <RotateTransform Angle="3.486"/>
                    <TranslateTransform/>
                </TransformGroup>
            </Image.RenderTransform>
        </Image>

    </Grid>
</Window>