<Window x:Class="CyberLikh.TaskHub"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CyberLikh Task Hub" Height="650" Width="950"
        WindowStartupLocation="CenterScreen"
        Background="#1a0000">
    <Grid Margin="0">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left: Input Form -->
        <Border Grid.Column="0" Background="#7f1d1d" Padding="20">
            <StackPanel>
                <TextBlock Text=" Task Hub" Foreground="White" FontSize="24"
                           FontWeight="Bold" Margin="0,0,0,20"/>

                <TextBlock Text="TITLE" Foreground="#fca5a5" FontSize="11" FontWeight="Bold" Margin="0,0,0,4"/>
                <TextBox x:Name="TitleInput" Padding="8" Margin="0,0,0,14"
                         Background="#450a0a" Foreground="White" BorderThickness="0" CaretBrush="White"/>

                <TextBlock Text="DESCRIPTION" Foreground="#fca5a5" FontSize="11" FontWeight="Bold" Margin="0,0,0,4"/>
                <TextBox x:Name="DescriptionInput" Padding="8" Margin="0,0,0,14"
                         Background="#450a0a" Foreground="White" BorderThickness="0" CaretBrush="White"
                         TextWrapping="Wrap" Height="60" AcceptsReturn="True"/>

                <TextBlock Text="REMINDER" Foreground="#fca5a5" FontSize="11" FontWeight="Bold" Margin="0,0,0,4"/>
                <TextBox x:Name="ReminderInput" Padding="8" Margin="0,0,0,20"
                         Background="#450a0a" Foreground="White" BorderThickness="0" CaretBrush="White"/>

                <Button Content="＋ ADD TASK" Click="AddTask_Click"
                        Background="#dc2626" Foreground="White" FontWeight="Bold"
                        Padding="12,10" BorderThickness="0" Cursor="Hand"/>
            </StackPanel>
        </Border>

        <!-- Right: Task List -->
        <Border Grid.Column="1" Background="#1a0000" Padding="20">
            <StackPanel>
                <TextBlock Text="Your Tasks" Foreground="White" FontSize="20"
                           FontWeight="Bold" Margin="0,0,0,15"/>
                <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="520">
                    <ItemsControl x:Name="TaskListContainer"/>
                </ScrollViewer>
            </StackPanel>
        </Border>
    </Grid>
</Window>
