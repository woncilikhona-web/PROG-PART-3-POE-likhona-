<Window x:Class="CyberLikh.QuizArena"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CyberLikh Quiz Arena" Height="600" Width="950"
        WindowStartupLocation="CenterScreen"
        Background="#0d0000">
    <Grid Margin="0">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="380"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT: Question panel with circular score badge -->
        <Border Grid.Column="0" Background="#450a0a" Padding="30">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Circular score badge -->
                <Border Grid.Row="0" Width="90" Height="90" CornerRadius="45"
                        Background="#7f1d1d" BorderBrush="#dc2626" BorderThickness="3"
                        HorizontalAlignment="Left" Margin="0,0,0,25">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock x:Name="ScoreDisplay" Text="0" Foreground="White"
                                   FontSize="28" FontWeight="Bold" HorizontalAlignment="Center"/>
                        <TextBlock Text="SCORE" Foreground="#fca5a5" FontSize="9"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Question text -->
                <StackPanel Grid.Row="1" VerticalAlignment="Center">
                    <TextBlock x:Name="QuestionCounter" Text="QUESTION 1 / 12"
                               Foreground="#dc2626" FontSize="12" FontWeight="Bold"
                               Margin="0,0,0,12"/>
                    <TextBlock x:Name="QuestionText" Text="Loading question..."
                               Foreground="White" FontSize="20" TextWrapping="Wrap"
                               LineHeight="28"/>
                </StackPanel>

                <!-- Feedback area -->
                <Border x:Name="FeedbackBox" Grid.Row="2" Background="#7f1d1d"
                        Padding="14" Margin="0,15,0,0" Visibility="Collapsed">
                    <TextBlock x:Name="FeedbackText" Foreground="White" FontSize="13"
                               TextWrapping="Wrap"/>
                </Border>
            </Grid>
        </Border>

        <!-- RIGHT: Answer tiles -->
        <Grid Grid.Column="1" Background="#0d0000">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="30" VerticalAlignment="Center">

                <Button x:Name="BtnA" Click="Answer_Click" Tag="A"
                        Margin="0,6" Padding="18,16" HorizontalContentAlignment="Left"
                        Background="#1a0000" Foreground="White" FontSize="15"
                        BorderThickness="1" BorderBrush="#7f1d1d" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="36"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Background="#dc2626" Width="28" Height="28"
                                            CornerRadius="14" HorizontalAlignment="Left" Margin="14,0,0,0">
                                        <TextBlock Text="A" Foreground="White" FontWeight="Bold"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ContentPresenter Grid.Column="1" Margin="14,0,0,0"
                                                      VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Button x:Name="BtnB" Click="Answer_Click" Tag="B"
                        Margin="0,6" Padding="18,16" HorizontalContentAlignment="Left"
                        Background="#1a0000" Foreground="White" FontSize="15"
                        BorderThickness="1" BorderBrush="#7f1d1d" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="36"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Background="#dc2626" Width="28" Height="28"
                                            CornerRadius="14" HorizontalAlignment="Left" Margin="14,0,0,0">
                                        <TextBlock Text="B" Foreground="White" FontWeight="Bold"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ContentPresenter Grid.Column="1" Margin="14,0,0,0"
                                                      VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Button x:Name="BtnC" Click="Answer_Click" Tag="C"
                        Margin="0,6" Padding="18,16" HorizontalContentAlignment="Left"
                        Background="#1a0000" Foreground="White" FontSize="15"
                        BorderThickness="1" BorderBrush="#7f1d1d" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="36"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Background="#dc2626" Width="28" Height="28"
                                            CornerRadius="14" HorizontalAlignment="Left" Margin="14,0,0,0">
                                        <TextBlock Text="C" Foreground="White" FontWeight="Bold"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ContentPresenter Grid.Column="1" Margin="14,0,0,0"
                                                      VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Button x:Name="BtnD" Click="Answer_Click" Tag="D"
                        Margin="0,6" Padding="18,16" HorizontalContentAlignment="Left"
                        Background="#1a0000" Foreground="White" FontSize="15"
                        BorderThickness="1" BorderBrush="#7f1d1d" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="36"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Background="#dc2626" Width="28" Height="28"
                                            CornerRadius="14" HorizontalAlignment="Left" Margin="14,0,0,0">
                                        <TextBlock Text="D" Foreground="White" FontWeight="Bold"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ContentPresenter Grid.Column="1" Margin="14,0,0,0"
                                                      VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- True/False tiles -->
                <StackPanel x:Name="TrueFalsePanel" Orientation="Horizontal"
                            HorizontalAlignment="Stretch" Visibility="Collapsed" Margin="0,10,0,0">
                    <Button Content="TRUE" Tag="True" Click="Answer_Click"
                            Background="#1a0000" Foreground="White" FontSize="16" FontWeight="Bold"
                            BorderThickness="1" BorderBrush="#7f1d1d"
                            Padding="0,20" Margin="0,0,6,0" Width="160" Cursor="Hand"/>
                    <Button Content="FALSE" Tag="False" Click="Answer_Click"
                            Background="#1a0000" Foreground="White" FontSize="16" FontWeight="Bold"
                            BorderThickness="1" BorderBrush="#7f1d1d"
                            Padding="0,20" Margin="6,0,0,0" Width="160" Cursor="Hand"/>
                </StackPanel>

            </StackPanel>

            <!-- Next button -->
            <Button x:Name="NextButton" Grid.Row="1" Content="NEXT →"
                    Click="Next_Click" Visibility="Collapsed"
                    HorizontalAlignment="Right" Margin="0,0,30,25"
                    Padding="22,12" FontSize="14" FontWeight="Bold" BorderThickness="0"
                    Background="#dc2626" Foreground="White" Cursor="Hand"/>
        </Grid>
    </Grid>
</Window>